SUPRA_MODEL_BACKEND=mlx
SUPRA_MODEL_LEGAL_REASONING=Qwen3-30B-A3B-Thinking-2507-MLX-4bit
SUPRA_MODEL_LEGAL_REASONING_HIGH_QUALITY=DeepSeek-R1-Distill-Qwen-32B-MLX-4bit
SUPRA_MODEL_DRAFTING=Qwen3-30B-A3B-Instruct-2507-MLX-4bit
SUPRA_MODEL_CRITIQUE=DeepSeek-R1-Distill-Qwen-32B-MLX-4bit
SUPRA_DEFAULT_CONTEXT_TOKENS=32768
SUPRA_MAX_CONTEXT_TOKENS=65536
SUPRA_ENABLE_COURTLISTENER=true
SUPRA_COURTLISTENER_BASE_URL=https://www.courtlistener.com/api/rest/v4
# Release builds read provider credentials from the device-bound macOS Keychain; explicit DEBUG and test composition may inject environment credentials.
# Keep this file limited to nonsecret configuration; do not add credential placeholders.
SUPRA_LEGAL_REQUIRE_CITATIONS=true
SUPRA_LEGAL_ALLOW_UNGROUNDED_LAW=false
SUPRA_LEGAL_VERIFY_CITATIONS=true
SUPRA_LEGAL_JURISDICTION_REQUIRED=true
SUPRA_LEGAL_LOG_QUERY_TERMS=false
# Government-records connectors (SEC EDGAR / CFPB complaints / NLRB exports).
# All public, key-less sources. SEC's fair-access policy requires a contact
# User-Agent (e.g. "Firm Name you@example.com") — it is not a secret.
SUPRA_SEC_EDGAR_USER_AGENT=
SUPRA_SEC_EDGAR_RATE_LIMIT_PER_SECOND=2
SUPRA_CFPB_RATE_LIMIT_PER_SECOND=2
SUPRA_NLRB_RATE_LIMIT_PER_SECOND=1
SUPRA_LEGAL_DATA_CACHE_DIR=
SUPRA_NLRB_LOCAL_DATA_DIR=
SUPRA_LEGAL_DATA_CONNECTORS_ENABLE_LIVE_TESTS=false

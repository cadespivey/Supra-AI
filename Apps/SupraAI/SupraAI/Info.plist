    <string>https://supralegal.ai/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>shxYsr9xkeOEx+LtTfQejWjhQ8YYcgIlXq+aVVuIFU4=</string>
    <!-- Required for sandboxed in-place install via Sparkle's Installer XPC. -->
    <key>SUEnableInstallerLauncherService</key>
    <true/>
    <!-- Enables automatic checks by default and suppresses the second-launch
         "check for updates?" permission prompt. -->
    <key>SUEnableAutomaticChecks</key>
    <true/>
</dict>
</plist>

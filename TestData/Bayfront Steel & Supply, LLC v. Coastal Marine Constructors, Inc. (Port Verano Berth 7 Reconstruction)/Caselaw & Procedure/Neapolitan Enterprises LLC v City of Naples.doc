}
}
{\b0 \cf24 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb400 
 The District Court of Appeal, Silberman, J., held that:
\par 
}
}
}
{\b0 \cf24 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
\u160\'3f
\par 
}
{\b0 \cf24 \f2 \ri0 \i0 \qj \fs20 \li0 
{\b0 \cf24 \f2 \ri0 \i0 \qj \fs20 \li0 
{\field {\*\fldinst HYPERLINK "#co_anchor_F32038189609_1" }{\fldrslt 

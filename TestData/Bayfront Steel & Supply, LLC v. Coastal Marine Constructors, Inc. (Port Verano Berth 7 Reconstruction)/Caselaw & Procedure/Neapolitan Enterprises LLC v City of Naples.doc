{\b0 \cf26 \f2 \ul0 \strike0 \i1 \fs20 \sa0 \sb0 
Topps v. State,
}
}
{\b0 \cf26 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
 865 So.2d 1253, 1254\u8211\'3f55 (Fla.2004)
}}}
{\b0 \cf24 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
; 
}
{\b0 \cf24 \f2 \i0 \fs20 
{\field {\*\fldinst HYPERLINK "https://1.next.westlaw.com/Link/RelatedInformation/Flag?documentGuid=Ifbc43f470c5b11d9bc18e8274af85244&transitionType=InlineKeyCiteFlags&originationContext=docHeaderFlag&Rank=0&ppcid=ab8035a5c4a941129019195e50064b51&contextData=(sc.CustomDigest)" }{\fldrslt 

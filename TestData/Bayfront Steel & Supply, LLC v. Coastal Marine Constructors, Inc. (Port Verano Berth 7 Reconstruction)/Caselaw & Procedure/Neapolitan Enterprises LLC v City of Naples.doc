 154 So.3d 1145, 1147 (Fla. 2d DCA 2014)
}}}
{\b0 \cf24 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
, 
}
{\b0 \cf24 \f2 \i1 \fs20 
{\b0 \cf24 \f2 \ul0 \strike0 \i1 \fs20 \sa0 \sb0 
review denied,
}
}
{\b0 \cf24 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
 
}
{\field {\*\fldinst HYPERLINK "https://www.westlaw.com/Link/Document/FullText?findType=Y&serNum=2036243301&pubNum=0003926&originatingDoc=I28b869c3c85411e5a795ac035416da91&refType=RP&originationContext=document&vr=3.0&rs=cblt1.0&transitionType=DocumentItem&contextData=(sc.CustomDigest)" }{\fldrslt 
{\b0 \cf26 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
171 So.3d 119 (Fla.2015)
}}}
{\b0 \cf24 \f2 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 
; 
}
{\b0 \cf24 \f2 \i0 \fs20 
{\field {\*\fldinst HYPERLINK "https://1.next.westlaw.com/Link/RelatedInformation/Flag?documentGuid=If5ed5757649411d9896bc143483b2851&transitionType=InlineKeyCiteFlags&originationContext=docHeaderFlag&Rank=0&ppcid=ab8035a5c4a941129019195e50064b51&contextData=(sc.CustomDigest)" }{\fldrslt 

\par 
}
}
}
}\b0 \cf37 \f2 \strike0 \i0 \fs20 \sa200 \sb0 \ri30 \ul0 \qj \ql \li30 \intbl \cell \row }}\par 
}
}
}
{\b0 \cf37 \f2 \ri0 \i0 \qj \fs20 \li0 
}
}
}
}
{\b0 \cf37 \f2 \ri0 \i0 \qj \fs20 \li0 
{\b0 \cf37 \f2 \ul0 \strike0 \i0 \fs20 
}
}
}
{\b0 \cf27 \f2 \i0 \fs20 

2
}\super \b0 \cf33 \f3 \ul0 \strike0 \i0 \fs20 \sa0 \sb0 }}
\par 
}
}
}\b0 \cf1 \f3 \ri0 \i0 \ql \li0 \fs20 \intbl \cell \intbl 
